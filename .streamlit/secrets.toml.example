# Exemplo de configuração de autenticação.
# Copie para .streamlit/secrets.toml e preencha com valores reais.
# NUNCA versione o secrets.toml — ele está no .gitignore.
#
# Gere a chave do cookie com:
#   python -c "import secrets; print(secrets.token_hex(32))"
#
# Gere os hashes de senha com:
#   python gerar_hash_senha.py

[cookie]
name = "clima_auth"
key = "TROCAR_POR_CHAVE_ALEATORIA_LONGA_MIN_32_CHARS"
expiry_days = 7

[credentials.usernames.cliente]
name = "Cliente RH"
password = "$2b$12$COLAR_HASH_BCRYPT_AQUI"

[credentials.usernames.admin]
name = "Vinicius"
password = "$2b$12$COLAR_HASH_BCRYPT_AQUI"
