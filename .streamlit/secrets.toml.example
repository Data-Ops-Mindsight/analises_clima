# Exemplo de configuração de autenticação.
# Copie este arquivo para .streamlit/secrets.toml e preencha com valores reais.
# NUNCA versione o secrets.toml — ele está no .gitignore.

[cookie]
name = "clima_auth"
key = "TROCAR_POR_CHAVE_ALEATORIA_LONGA_32_CHARS"
expiry_days = 7

# Para cada usuário: execute gerar_hash_senha.py e cole o hash gerado em "password".
[credentials.usernames.cliente]
name = "Cliente RH"
password = "COLAR_HASH_AQUI"

[credentials.usernames.admin]
name = "Vinicius"
password = "COLAR_HASH_AQUI"
